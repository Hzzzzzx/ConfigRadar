SPRING_PROFILES_ACTIVE=dev
SPRING_CONFIG_LOCATION=classpath:/,file:/etc/acme/
SPRING_CONFIG_ADDITIONAL_LOCATION=file:/opt/acme/
REDIS_PASSWORD=${REDIS_PASSWORD:local-secret}
export FEATURE_FLAG=true
QUOTED_NAME="config radar"
SHELL_DEFAULT=${SHELL_DEFAULT:-fallback}
SPRING_APPLICATION_JSON={"management":{"server":{"port":9090}},"feature":{"json":true}}
INLINE_COMMENT=enabled # rollout flag
JAVA_TOOL_OPTIONS=-Dtool.mode=worker -Dtool.timeout=PT5S
